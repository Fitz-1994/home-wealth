# MySQL
MYSQL_ROOT_PASSWORD=change_me_root_pwd
MYSQL_USER=hwuser
MYSQL_PASSWORD=change_me_db_pwd

# JWT（至少32位随机字符串）
JWT_SECRET=change_me_to_a_very_long_random_secret_key_min_32_chars
JWT_EXPIRATION=86400000

# AI 视觉识别配置（用于持仓截图识别功能）
# provider: anthropic（默认）或 openai-compatible（MiniMax/OpenAI 等）
AI_PROVIDER=anthropic
AI_API_KEY=sk-ant-xxxx
# AI_API_URL=https://api.minimax.chat/v1/chat/completions   # openai-compatible 时填写
# AI_MODEL=MiniMax-M2.5                                      # openai-compatible 时填写
