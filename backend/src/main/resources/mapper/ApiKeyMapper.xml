<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.homewealth.mapper.ApiKeyMapper">

    <resultMap id="ApiKeyMap" type="com.homewealth.model.ApiKey">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="keyName" column="key_name"/>
        <result property="keyValue" column="key_value"/>
        <result property="keyPrefix" column="key_prefix"/>
        <result property="isActive" column="is_active"/>
        <result property="lastUsedAt" column="last_used_at"/>
        <result property="expiresAt" column="expires_at"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findById" resultMap="ApiKeyMap">
        SELECT * FROM api_key WHERE id = #{id}
    </select>

    <select id="findByKeyValue" resultMap="ApiKeyMap">
        SELECT * FROM api_key WHERE key_value = #{keyValue} AND is_active = 1
    </select>

    <select id="findByUserId" resultMap="ApiKeyMap">
        SELECT * FROM api_key WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO api_key (user_id, key_name, key_value, key_prefix, is_active, expires_at)
        VALUES (#{userId}, #{keyName}, #{keyValue}, #{keyPrefix}, 1, #{expiresAt})
    </insert>

    <update id="deactivate">
        UPDATE api_key SET is_active = 0 WHERE id = #{id} AND user_id = #{userId}
    </update>

    <update id="updateLastUsedAt">
        UPDATE api_key SET last_used_at = #{lastUsedAt} WHERE id = #{id}
    </update>

</mapper>
